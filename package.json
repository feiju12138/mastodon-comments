    "type": "git",
    "url": "git+https://github.com/feiju12138/mastodon-comments.git"
  },
  "bugs": {
    "url": "https://github.com/feiju12138/mastodon-comments/issues"
  },
  "homepage": "https://feiju12138.github.io/mastodon-comments/",
  "devDependencies": {
    "rollup": "^2.80.0",
    "rollup-plugin-banner2": "^1.3.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-terser": "^7.0.2"
  }
}
